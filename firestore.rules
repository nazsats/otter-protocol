rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: owner writes their own, any auth user reads (leaderboard/referral lookup)
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Referrals: auth users can read and create
    match /referrals/{referralId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Mission progress: owner reads/writes their own
    match /user_missions/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Initiation progress: owner reads/writes their own signal weight + tasks
    match /user_initiation/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Task overrides: any auth user reads (to show admin edits), no client writes
    match /task_overrides/{taskId} {
      allow read:                   if request.auth != null;
      allow create, update, delete: if false; // Admin SDK only
    }

    // Pending approvals: auth users can read own + create submissions
    match /pending_approvals/{approvalId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Admin SDK only
    }

    // OTTER claims: server writes, user reads own
    match /otter_claims/{claimId} {
      allow read:             if request.auth != null
                                && request.auth.uid == resource.data.uid;
      allow create, update, delete: if false;
    }

    // Drop claims: server writes, user reads own
    match /drop_claims/{claimId} {
      allow read:             if request.auth != null
                                && request.auth.uid == resource.data.uid;
      allow create, update, delete: if false;
    }

    // Drops: public read, server writes
    match /drops/{dropId} {
      allow read:                   if true;
      allow create, update, delete: if false;
    }

    // Activity feed: public read. Clients may ONLY create their own "join"
    // entries (used by createUserProfile). Value-bearing events (claims, drops,
    // meme rewards) are written server-side via the Admin SDK so a user can't
    // forge a fake "claimed 10000 OTTER" line into the public feed.
    match /activity/{entryId} {
      allow read:   if true;
      allow create: if request.auth != null
                      && request.resource.data.type == 'join'
                      && !('amount' in request.resource.data)
                      && !('txHash' in request.resource.data);
      allow update, delete: if false;
    }

    // Rate limiting: server only
    match /rate_limits/{key} {
      allow read, write: if false;
    }

    // Treasury nonce lock: server only (Admin SDK)
    match /treasury_state/{address} {
      allow read, write: if false;
    }

    // Memes: public read, server writes
    match /memes/{memeId} {
      allow read:                   if true;
      allow create, update, delete: if false;
    }

    // Meme votes: auth users read, server writes
    match /meme_votes/{voteId} {
      allow read:                   if request.auth != null;
      allow create, update, delete: if false;
    }

    // OTTER whitelist: server writes, user reads own
    match /otter_whitelist/{uid} {
      allow read:                   if request.auth != null && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // Admin settings: contracts + social are public-readable (used by the app at runtime)
    match /admin_settings/{docId} {
      allow read:  if docId == "contracts" || docId == "social";
      allow write: if false; // Admin SDK only
    }

    // Mission overrides: any auth user can read, no client writes
    match /mission_overrides/{missionId} {
      allow read:                   if request.auth != null;
      allow create, update, delete: if false; // Admin SDK only
    }

    // Admin log: server only
    match /admin_log/{entryId} {
      allow read, write: if false;
    }

    // Access codes: server only (managed via admin SDK)
    match /access_codes/{codeId} {
      allow read, write: if false;
    }

    // Waitlist: anyone can submit an email (no auth required), no client reads
    match /waitlist/{entryId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
